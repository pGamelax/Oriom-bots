:80 {
    # Rotas de API vão para o backend
    handle /api/* {
        reverse_proxy {$VITE_API_URL}
    }

    # Todo o resto serve os arquivos estáticos com fallback SPA
    handle {
        root * /srv
        try_files {path} /index.html
        file_server

        # index.html nunca deve ser cacheado (SPA entry point)
        @html path *.html /
        header @html Cache-Control "no-cache, no-store, must-revalidate"
    }
}
