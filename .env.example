# ── Backend ────────────────────────────────────────────────────────────────────
# Chave secreta do better-auth (gere com: openssl rand -base64 32)
BETTER_AUTH_SECRET=troque_por_uma_chave_secreta

# URL pública do backend (usado pelo better-auth para callbacks)
BETTER_AUTH_URL=https://api.seudominio.com

# URL do frontend (para configurar CORS no backend)
FRONTEND_URL=https://seudominio.com

# URL pública do backend (para gerar o webhook do SyncPay)
APP_URL=https://api.seudominio.com

# ── Frontend ───────────────────────────────────────────────────────────────────
# URL do backend que o browser vai usar (baked no build do Vite)
VITE_API_URL=https://api.seudominio.com
